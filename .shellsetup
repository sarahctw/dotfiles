# Assumes compatibility with both bash and zh
# === Editor and Notes Convenience Setups ===
if [ "$EMACS" = "" ]; then export TERM=xterm-256color; fi
if [ -n "${BASH_VERSION-}" ]; then
  [ -r "$HOME/.git-completion.bash" ] && . "$HOME/.git-completion.bash"
elif [ -n "${ZSH_VERSION-}" ]; then
  autoload -Uz compinit && compinit
  # Source the zsh-specific version instead
  [ -r "$HOME/.git-completion.zsh" ] && . "$HOME/.git-completion.zsh"
fi

export NOTES="$HOME/Dropbox/Apps/NotationalVelocity"     # notes folder for scripting access
export EDITOR="$(which vim)"                             # use vim for simple editing

# === PATH editing ===
export PATH="/usr/local/bin:$PATH"                      # local binaries
export PATH="/usr/local/yum:$PATH"                      # yum stuff, random things rely on it
export PATH="/usr/local/share/npm/bin:$PATH"            # npm global
export PATH="$HOME/.local/bin:$PATH"                    # other local binaries
export PATH="$HOME/.npm-packages/bin:$PATH"             # npm explicit-set global
export PATH="/usr/local/go/bin:$PATH"                   # add go to path
export PATH="/usr/local/terraform/bin:$PATH"            # terraform directory
export PATH="$HOME/.cargo/bin:$PATH"                    # rust cargo directory
export PATH="$HOME/dotfiles/scripts:$PATH"              # my own custom scripts

# === Language-specific setups ===
export ANDROID_HOME="$HOME/Library/Android/sdk"         # Android
export ANDROID_SDK_ROOT="$HOME/Library/Android/sdk"         # Android
export GOPATH="$HOME/Dev/Go"                            # Golang
export NVM_DIR="$HOME/.nvm"                             # NVM directory

# === Language-dependent paths ===
export PATH="$PATH:$ANDROID_HOME/tools:$ANDROID_HOME/platform-tools"

# Environment manager initializations
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"  # This loads nvm

case "$(uname -s)" in
  Darwin)
    export JAVA_HOME="$("/usr/libexec/java_home")"  # Java for Android Studio
    if [ "$(uname -m)" = "arm64" ]; then
      eval "$(/opt/homebrew/bin/brew shellenv)"
      export PATH="/opt/homebrew/opt/ruby/bin:$PATH"
      export PATH="$(gem environment gemdir)/bin:$PATH"
    fi
    ;;
  Linux) : ;;
esac

# Source .env if it exists in our dotfiles
[ -f "$HOME/dotfiles/.env" ] && . "$HOME/dotfiles/.env"

# --- per-machine Git overlay + SSH signing bootstrap ---

# Ensure per-machine overlay file exists
touch "$HOME/.gitconfig.local"

git_cfg_local() { git config --file "$HOME/.gitconfig.local" "$@"; }

# Choose a private key for signing if present (write to LOCAL, not global)
if [ -f "$HOME/.ssh/id_ed25519" ]; then
  git_cfg_local user.signingkey "$HOME/.ssh/id_ed25519"
elif [ -f "$HOME/.ssh/id_rsa" ]; then
  git_cfg_local user.signingkey "$HOME/.ssh/id_rsa"
fi

# Resolve principals (emails): env var > existing git config > error out
commit_emails=""
if [ -n "${GIT_COMMIT_EMAILS:-}" ]; then
  commit_emails="$GIT_COMMIT_EMAILS"
else
  commit_emails="$(git config --global --get user.email || true)"
fi

# Only proceed if we have emails and at least one key
have_key=false
for pub in "$HOME/.ssh/id_ed25519.pub" "$HOME/.ssh/id_rsa.pub"; do
  [ -f "$pub" ] && have_key=true && break
done

if [ -z "$commit_emails" ]; then
  >&2 echo "[git-ssh-signing] No commit emails set; skipping allowed_signers."
elif [ "$have_key" = false ]; then
  >&2 echo "[git-ssh-signing] No SSH public keys found; skipping allowed_signers."
else
  # You can keep gpg.format in the base .gitconfig if you prefer.
  # If you want it per-machine, write it to the LOCAL overlay instead:
  git_cfg_local gpg.format ssh
  git_cfg_local gpg.ssh.allowedSignersFile "$HOME/.ssh/allowed_signers"

  # Rebuild allowed_signers
  mkdir -p "$HOME/.ssh"
  : > "$HOME/.ssh/allowed_signers"
  for pub in "$HOME/.ssh/id_ed25519.pub" "$HOME/.ssh/id_rsa.pub"; do
    [ -f "$pub" ] || continue
    printf "%s " "$commit_emails" >> "$HOME/.ssh/allowed_signers"
    cat "$pub" >> "$HOME/.ssh/allowed_signers"
  done
  chmod 0644 "$HOME/.ssh/allowed_signers"
fi

# Ensure the base .gitconfig includes the local overlay (ONE entry)
if ! git config --global --get-all include.path | grep -q ".gitconfig.local"; then
  git config --global --add include.path ".gitconfig.local"
fi

# --- end bootstrap ---

# Language-specific paths, require language-specific setups
export PATH="$GOPATH/bin:$PATH"                         # add go binaries

# Install powerline fonts and Spacemacs if not available
if [ ! -f "$HOME/.emacs.d/spacemacs.mk" ]; then
    echo "Installing Spacemacs..."
    rm -rf $HOME/.emacs.d
    git clone https://github.com/powerline/fonts.git --depth=1 $HOME/fonts && \
        $HOME/fonts/install.sh && \
        rm -rf $HOME/fonts
    git clone https://github.com/syl20bnr/spacemacs $HOME/.emacs.d
fi
